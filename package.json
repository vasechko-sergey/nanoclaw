{
  "name": "nanoclaw",
  "version": "2.0.62",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "main": "dist/index.js",
  "bin": {
    "ncl": "bin/ncl"
  },
  "scripts": {
    "build": "tsc -p shared/ios-app-protocol && tsc",
    "build:protocol": "tsc -p shared/ios-app-protocol",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "pretypecheck": "tsc -p shared/ios-app-protocol",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "setup:auto": "tsx setup/auto.ts",
    "ncl": "tsx src/cli/client.ts",
    "chat": "tsx scripts/chat.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:all": "bash scripts/test-all.sh",
    "e2e:harness": "tsx scripts/e2e-harness.ts"
  },
  "dependencies": {
    "@chat-adapter/telegram": "4.26.0",
    "@clack/core": "^1.2.0",
    "@clack/prompts": "^1.2.0",
    "@onecli-sh/sdk": "^0.5.0",
    "better-sqlite3": "12.10.0",
    "chat": "^4.24.0",
    "cron-parser": "5.5.0",
    "kleur": "^4.1.5",
    "ws": "^8.20.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
