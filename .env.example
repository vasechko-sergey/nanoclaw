# iOS App WebSocket channel
IOS_APP_TOKEN=                    # Random secret (openssl rand -hex 32)
IOS_APP_PORT=3001                 # WebSocket server port

# iOS App APNs push (optional — push when app is backgrounded)
IOS_APNS_KEY_ID=                  # Key ID from Apple Developer (.p8)
IOS_APNS_TEAM_ID=                 # Team ID from Apple Developer
IOS_APNS_BUNDLE_ID=               # Bundle ID (e.g. com.yourname.jarvis)
IOS_APNS_KEY=                     # Contents of the .p8 file (BEGIN PRIVATE KEY)
